# ─────────────────────────────────────────────
#  Project XXX — Frontend Environment Variables
# ─────────────────────────────────────────────
#
# Copy this file to .env.local for local development.
# On Vercel, set these in the project's Environment Variables dashboard.
#
# LOCAL DEV — leave VITE_API_URL unset; Vite proxy handles /api → localhost:8000
# PRODUCTION — set VITE_API_URL to your Railway backend URL

VITE_API_URL=https://your-backend.up.railway.app/api
